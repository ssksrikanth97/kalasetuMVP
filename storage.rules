
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Allow anyone to read public profiles and product images
    match /artists/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /institutions/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /products/{allPaths=**} {
        allow read: if true;
        allow write: if request.auth != null;
    }

    match /events/{allPaths=**} {
        allow read: if true;
        allow write: if request.auth != null;
    }
  }
}
